{
  "manifest_version": 3,
  "name": "JobPilot Clipper",
  "version": "1.3.0",
  "description": "Clip job descriptions directly from LinkedIn and Indeed to your JobPilot tracker.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": "logo.svg"
  },
  "icons": {
    "128": "logo.svg"
  },
  "permissions": [
    "storage",
    "activeTab",
    "contextMenus",
    "scripting"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://pk.indeed.com/*",
    "https://shaheer-ipynb-jobpilot-api.hf.space/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*",
        "https://pk.indeed.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["logo.svg"],
      "matches": ["https://www.linkedin.com/*", "https://pk.indeed.com/*"]
    }
  ]
}
